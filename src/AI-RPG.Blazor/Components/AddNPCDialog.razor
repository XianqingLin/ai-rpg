@using AI_RPG.Application.DTOs

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudTextField @bind-Value="_request.Name" 
                         Label="NPC 名称" 
                         Required="true"
                         RequiredError="请输入 NPC 名称"
                         Variant="Variant.Outlined"
                         Class="mb-4" />

            <MudTextField @bind-Value="_request.Appearance" 
                         Label="外貌描述" 
                         Required="true"
                         RequiredError="请输入外貌描述"
                         HelperText="例如：白发苍苍的老者，穿着朴素的长袍"
                         Variant="Variant.Outlined"
                         Class="mb-4" />

            <MudTextField @bind-Value="_request.Personality" 
                         Label="性格特点" 
                         Required="true"
                         RequiredError="请输入性格特点"
                         HelperText="例如：和蔼可亲，乐于助人，但有时固执"
                         Variant="Variant.Outlined"
                         Class="mb-4" />

            <MudTextField @bind-Value="_request.Background" 
                         Label="背景故事" 
                         Required="true"
                         RequiredError="请输入背景故事"
                         Lines="3"
                         HelperText="例如：村庄的长者，见证了村庄的兴衰"
                         Variant="Variant.Outlined"
                         Class="mb-4" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">取消</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="!_isValid">添加</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private MudForm? _form;
    private bool _isValid;

    private AddNPCRequest _request = new();

    private async Task Submit()
    {
        if (_form == null) return;
        
        await _form.Validate();
        if (_isValid)
        {
            MudDialog.Close(DialogResult.Ok(_request));
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
