@page "/sessions/create"
@inject SessionService SessionService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>创建会话 - AI-RPG</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">创建新会话</MudText>

<MudPaper Elevation="2" Class="pa-4">
    <MudForm @ref="_form" @bind-IsValid="_isValid">
        <MudTextField @bind-Value="_request.Title" 
                     Label="会话标题" 
                     Required="true"
                     RequiredError="请输入会话标题"
                     Variant="Variant.Outlined"
                     Class="mb-4" />

        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_request.Genre" 
                             Label="游戏类型" 
                             Required="true"
                             RequiredError="请输入游戏类型"
                             HelperText="例如：奇幻、科幻、现代、恐怖"
                             Variant="Variant.Outlined"
                             Class="mb-4" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_request.Theme" 
                             Label="主题" 
                             Required="true"
                             RequiredError="请输入主题"
                             HelperText="例如：冒险、悬疑、战争、爱情"
                             Variant="Variant.Outlined"
                             Class="mb-4" />
            </MudItem>
        </MudGrid>

        <MudTextField @bind-Value="_request.WorldDescription" 
                     Label="世界观描述" 
                     Required="true"
                     RequiredError="请输入世界观描述"
                     Lines="4"
                     Variant="Variant.Outlined"
                     Class="mb-4" />

        <MudDivider Class="my-4" />

        <MudText Typo="Typo.h6" Class="mb-2">初始场景</MudText>

        <MudTextField @bind-Value="_request.InitialScene.Name" 
                     Label="场景名称" 
                     Required="true"
                     RequiredError="请输入场景名称"
                     Variant="Variant.Outlined"
                     Class="mb-4" />

        <MudTextField @bind-Value="_request.InitialScene.Description" 
                     Label="场景描述" 
                     Required="true"
                     RequiredError="请输入场景描述"
                     Lines="3"
                     Variant="Variant.Outlined"
                     Class="mb-4" />

        <MudDivider Class="my-4" />

        <MudButton Variant="Variant.Filled" 
                  Color="Color.Primary" 
                  OnClick="CreateSessionAsync"
                  Disabled="!_isValid || _isSubmitting"
                  StartIcon="@Icons.Material.Filled.Create">
            @if (_isSubmitting)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">创建中...</MudText>
            }
            else
            {
                <MudText>创建会话</MudText>
            }
        </MudButton>

        <MudButton Variant="Variant.Outlined" 
                  Color="Color.Secondary" 
                  OnClick="Cancel"
                  Class="ml-2">
            取消
        </MudButton>
    </MudForm>
</MudPaper>

@code {
    private MudForm? _form;
    private bool _isValid;
    private bool _isSubmitting;

    private CreateSessionRequest _request = new()
    {
        Title = "",
        Genre = "奇幻",
        Theme = "冒险",
        WorldDescription = "一个充满魔法与剑的奇幻世界，勇敢的冒险者们在这里书写传奇。",
        InitialScene = new SceneDto
        {
            Name = "起始村庄",
            Description = "一个宁静的小村庄，炊烟袅袅，村民们友善而热情。你是这里的冒险者，即将踏上未知的旅程。"
        }
    };

    private void Cancel()
    {
        Navigation.NavigateTo("sessions");
    }

    private async Task CreateSessionAsync()
    {
        if (_form == null) return;
        
        await _form.Validate();
        if (!_isValid) return;

        _isSubmitting = true;
        try
        {
            var session = await SessionService.CreateAsync(_request);
            if (session != null)
            {
                Snackbar.Add("会话创建成功！", Severity.Success);
                Navigation.NavigateTo($"/sessions/{session.Id}");
            }
            else
            {
                Snackbar.Add("创建会话失败", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"创建会话失败: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
