@page "/sessions/{SessionId}"
@inject SessionService SessionService
@inject DialogueService DialogueService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>@(_session?.Title ?? "会话") - AI-RPG</PageTitle>

@if (_isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4" />
}
else if (_session == null)
{
    <MudAlert Severity="Severity.Error">会话不存在或已删除</MudAlert>
}
else
{
    <MudGrid>
        <!-- 左侧：会话信息 -->
        <MudItem xs="12" md="3">
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6">@_session.Title</MudText>
                <MudChip T="string" Color="GetStatusColor(_session.Status)" Size="Size.Small" Class="my-2">
                    @GetStatusText(_session.Status)
                </MudChip>
                <MudText Typo="Typo.caption">创建于 @_session.CreatedAt.ToString("yyyy-MM-dd HH:mm")</MudText>
                
                <MudDivider Class="my-2" />
                
                <MudText Typo="Typo.subtitle2">当前场景</MudText>
                <MudText Typo="Typo.body2">@_session.CurrentScene.Name</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">@_session.CurrentScene.Description</MudText>
                
                <MudDivider Class="my-2" />
                
                <MudButton Variant="Variant.Outlined" 
                          Color="Color.Primary" 
                          Size="Size.Small"
                          OnClick="ShowAddNPCDialog"
                          StartIcon="@Icons.Material.Filled.Add"
                          FullWidth="true"
                          Class="mb-2">
                    添加 NPC
                </MudButton>

                @if (_session.Status == "Preparing")
                {
                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Success" 
                              Size="Size.Small"
                              OnClick="StartSession"
                              FullWidth="true">
                        开始会话
                    </MudButton>
                }
            </MudPaper>

            <!-- 参与者列表 -->
            <MudPaper Elevation="2" Class="pa-4">
                <MudText Typo="Typo.subtitle2" Class="mb-2">参与者</MudText>
                
                @if (_session.Players.Any())
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">玩家</MudText>
                    @foreach (var player in _session.Players)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="ma-1">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-1" />
                            @player.Name
                        </MudChip>
                    }
                }

                @if (_session.NPCs.Any())
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">NPC</MudText>
                    @foreach (var npc in _session.NPCs)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Class="ma-1">
                            <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small" Class="mr-1" />
                            @npc.Name
                        </MudChip>
                    }
                }

                @if (!_session.Players.Any() && !_session.NPCs.Any())
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">暂无参与者</MudText>
                }
            </MudPaper>
        </MudItem>

        <!-- 右侧：对话区域 -->
        <MudItem xs="12" md="9">
            <MudPaper Elevation="2" Class="d-flex flex-column" Style="height: 70vh;">
                <!-- 消息列表 -->
                <MudList T="DialogueTurnDto" Dense="true" Class="flex-1 overflow-auto pa-4" @ref="_messageList">
                    @if (_messages.Count == 0)
                    {
                        <MudText Align="Align.Center" Class="mud-text-secondary mt-8">
                            暂无消息，开始你的冒险吧！
                        </MudText>
                    }
                    else
                    {
                        @foreach (var message in _messages)
                        {
                            <div class="d-flex @(IsPlayerMessage(message) ? "justify-end" : "justify-start") mb-2">
                                <MudPaper Elevation="1" 
                                         Class="@GetMessageClass(message)"
                                         Style="max-width: 70%; word-break: break-word;">
                                    <MudText Typo="Typo.caption" Class="d-block mb-1">
                                        @message.SpeakerName
                                    </MudText>
                                    <MudText Typo="Typo.body2">@message.Content</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mt-1" Style="font-size: 10px;">
                                        @message.Timestamp.ToString("HH:mm:ss")
                                    </MudText>
                                </MudPaper>
                            </div>
                        }
                    }
                    
                    @if (_isStreaming)
                    {
                        <div class="d-flex justify-start mb-2">
                            <MudPaper Elevation="1" Class="pa-3" Style="max-width: 70%;">
                                <MudText Typo="Typo.caption" Class="d-block mb-1">@_streamingSpeaker</MudText>
                                <MudText Typo="Typo.body2">@_streamingContent</MudText>
                                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Size="Size.Small" Class="mt-2" />
                            </MudPaper>
                        </div>
                    }
                </MudList>

                <!-- 输入区域 -->
                <MudDivider />
                <div class="pa-4">
                    @if (_session.Status == "Running")
                    {
                        <MudGrid>
                            <MudItem xs="12">
                                @if (!_isJoined)
                                {
                                    <MudButton Variant="Variant.Filled" 
                                              Color="Color.Primary" 
                                              OnClick="JoinSession"
                                              FullWidth="true">
                                        加入会话
                                    </MudButton>
                                }
                                else
                                {
                                    <MudTextField @bind-Value="_messageInput"
                                                 Label="输入消息..."
                                                 Variant="Variant.Outlined"
                                                 Adornment="Adornment.End"
                                                 AdornmentIcon="@Icons.Material.Filled.Send"
                                                 OnAdornmentClick="SendMessageAsync"
                                                 OnKeyDown="OnKeyDown"
                                                 Disabled="_isSending"
                                                 AutoFocus="true" />
                                }
                            </MudItem>
                        </MudGrid>
                    }
                    else if (_session.Status == "Preparing")
                    {
                        <MudAlert Severity="Severity.Info">会话准备中，点击左侧"开始会话"按钮开始游戏</MudAlert>
                    }
                    else if (_session.Status == "Paused")
                    {
                        <MudAlert Severity="Severity.Warning">会话已暂停</MudAlert>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Error">会话已结束</MudAlert>
                    }
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter]
    public string SessionId { get; set; } = "";

    private SessionDto? _session;
    private List<DialogueTurnDto> _messages = new();
    private MudList<DialogueTurnDto>? _messageList;
    
    private bool _isLoading = true;
    private bool _isJoined = false;
    private bool _isSending = false;
    private bool _isStreaming = false;
    
    private string _messageInput = "";
    private string _streamingContent = "";
    private string _streamingSpeaker = "";
    
    private string _currentUserId = "user-001";
    private string _currentPlayerName = "勇者";
    private string? _currentPlayerId;

    protected override async Task OnInitializedAsync()
    {
        await LoadSessionAsync();
    }

    private async Task LoadSessionAsync()
    {
        _isLoading = true;
        try
        {
            _session = await SessionService.GetAsync(SessionId);
            if (_session != null)
            {
                // 检查当前用户是否已加入
                var player = _session.Players.FirstOrDefault(p => p.UserId == _currentUserId);
                _isJoined = player != null;
                _currentPlayerId = player?.Id;
                
                // 加载历史消息
                _messages = _session.RecentHistory.ToList();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"加载会话失败: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task JoinSession()
    {
        var request = new JoinSessionRequest
        {
            SessionId = SessionId,
            UserId = _currentUserId,
            PlayerName = _currentPlayerName
        };

        var result = await SessionService.JoinAsync(SessionId, request);
        if (result != null)
        {
            _isJoined = true;
            _currentPlayerId = result.Players.FirstOrDefault(p => p.UserId == _currentUserId)?.Id;
            Snackbar.Add("成功加入会话！", Severity.Success);
            await LoadSessionAsync();
        }
        else
        {
            Snackbar.Add("加入会话失败", Severity.Error);
        }
    }

    private async Task StartSession()
    {
        var result = await SessionService.StartAsync(SessionId);
        if (result != null)
        {
            Snackbar.Add("会话已开始！", Severity.Success);
            await LoadSessionAsync();
        }
        else
        {
            Snackbar.Add("开始会话失败", Severity.Error);
        }
    }

    private async Task SendMessageAsync()
    {
        if (string.IsNullOrWhiteSpace(_messageInput) || _currentPlayerId == null) return;

        _isSending = true;
        var userMessage = _messageInput;
        _messageInput = "";

        try
        {
            var request = new SendMessageRequest
            {
                SessionId = SessionId,
                PlayerId = _currentPlayerId,
                Message = userMessage
            };

            // 先显示用户消息
            _messages.Add(new DialogueTurnDto
            {
                SpeakerId = _currentPlayerId,
                SpeakerName = _currentPlayerName,
                Content = userMessage,
                Type = "Speech",
                Timestamp = DateTime.Now
            });

            // 调用 API 获取 AI 响应
            var response = await DialogueService.SendMessageAsync(request);
            
            if (response?.Success == true)
            {
                _messages.Add(new DialogueTurnDto
                {
                    SpeakerId = response.SpeakerId,
                    SpeakerName = response.SpeakerName,
                    Content = response.Content,
                    Type = response.Type,
                    Timestamp = response.Timestamp
                });
            }
            else
            {
                Snackbar.Add(response?.ErrorMessage ?? "发送消息失败", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"发送消息失败: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSending = false;
            await ScrollToBottomAsync();
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessageAsync();
        }
    }

    private async Task ShowAddNPCDialog()
    {
        var parameters = new DialogParameters();
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small };
        
        var dialog = await DialogService.ShowAsync<AddNPCDialog>("添加 NPC", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: AddNPCRequest request })
        {
            var npc = await SessionService.AddNPCAsync(SessionId, request);
            if (npc != null)
            {
                Snackbar.Add($"NPC {npc.Name} 添加成功！", Severity.Success);
                await LoadSessionAsync();
            }
            else
            {
                Snackbar.Add("添加 NPC 失败", Severity.Error);
            }
        }
    }

    private async Task ScrollToBottomAsync()
    {
        // 简单延迟让 UI 更新
        await Task.Delay(100);
        StateHasChanged();
    }

    private bool IsPlayerMessage(DialogueTurnDto message)
    {
        return message.SpeakerId == _currentPlayerId;
    }

    private string GetMessageClass(DialogueTurnDto message)
    {
        return IsPlayerMessage(message) ? "pa-3 mud-theme-primary" : "pa-3";
    }

    private Color GetStatusColor(string status)
    {
        return status switch
        {
            "Running" => Color.Success,
            "Paused" => Color.Warning,
            "Preparing" => Color.Info,
            "Ended" => Color.Error,
            _ => Color.Default
        };
    }

    private string GetStatusText(string status)
    {
        return status switch
        {
            "Running" => "进行中",
            "Paused" => "已暂停",
            "Preparing" => "准备中",
            "Ended" => "已结束",
            _ => status
        };
    }
}
