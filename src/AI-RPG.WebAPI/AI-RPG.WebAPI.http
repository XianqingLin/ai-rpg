@WebAPI_HostAddress = http://localhost:5237

### 创建会话
POST {{WebAPI_HostAddress}}/api/sessions
Content-Type: application/json

{
  "title": "测试跑团会话",
  "genre": "奇幻",
  "theme": "冒险",
  "worldDescription": "一个充满魔法与剑的奇幻世界",
  "initialScene": {
    "name": "起始村庄",
    "description": "一个宁静的小村庄，你是这里的冒险者"
  }
}

### 获取会话详情
GET {{WebAPI_HostAddress}}/api/sessions/{sessionId}
Accept: application/json

### 玩家加入会话
POST {{WebAPI_HostAddress}}/api/sessions/{sessionId}/join
Content-Type: application/json

{
  "userId": "user-001",
  "playerName": "勇者小明"
}

### 开始会话
POST {{WebAPI_HostAddress}}/api/sessions/{sessionId}/start

### 添加 NPC
POST {{WebAPI_HostAddress}}/api/sessions/{sessionId}/npcs
Content-Type: application/json

{
  "name": "村长",
  "appearance": "白发苍苍的老者，穿着朴素的长袍",
  "personality": "和蔼可亲，乐于助人",
  "background": "村庄的长者，见证了村庄的兴衰"
}

### 发送消息（玩家与AI交互）
POST {{WebAPI_HostAddress}}/api/sessions/{sessionId}/dialogue
Content-Type: application/json

{
  "playerId": "{playerId}",
  "message": "你好，我想了解一下这个世界"
}

### 获取对话历史
GET {{WebAPI_HostAddress}}/api/sessions/{sessionId}/dialogue/history?count=20
Accept: application/json

### 结束会话
POST {{WebAPI_HostAddress}}/api/sessions/{sessionId}/end

###
