# AI-RPG WebAPI 环境变量配置
# 复制此文件为 .env 并填写实际值

# PostgreSQL 数据库连接字符串（必需）
Database__ConnectionString=Host=localhost;Port=5432;Database=airpg;Username=postgres;Password=your_password

# 可选：Kimi AI 配置
Kimi__ApiKey=your_kimi_api_key

# 可选：其他服务配置
# Qdrant__Host=localhost
# Qdrant__Port=6334
# Neo4j__Uri=bolt://localhost:7687
# Neo4j__Username=neo4j
# Neo4j__Password=password
# Redis__ConnectionString=localhost:6379
